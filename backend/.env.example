# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here

# ── Device API key (ESP32 hardware endpoint) ───────────────────────────────────
DEVICE_API_KEY=your_device_api_key_here

# ── Firebase (Realtime Database — ESP8266 vitals) ─────────────────────────────
# Web API key from: Firebase console → Project Settings → General → Web API Key
FIREBASE_API_KEY=AIzaSyDHbSqJ0CPPGget2JsRZxXwCDY_A7uwC5E

# Realtime Database URL (no trailing slash)
FIREBASE_DATABASE_URL=https://vitalwatch123-default-rtdb.firebaseio.com

# Firebase Auth account used by the ESP8266 (same email/password as the hardware)
FIREBASE_USER_EMAIL=braniax123@gmail.com
FIREBASE_USER_PASSWORD=aaaaaaaa

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
